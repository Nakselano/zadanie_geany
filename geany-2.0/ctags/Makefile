	$(AM_V_at)$(am__mv) gnu_regex/$(DEPDIR)/libgnu_regex_la-regcomp.Tpo gnu_regex/$(DEPDIR)/libgnu_regex_la-regcomp.Plo
#	$(AM_V_CC)source='gnu_regex/regcomp.c' object='gnu_regex/libgnu_regex_la-regcomp.lo' libtool=yes \
#	DEPDIR=$(DEPDIR) $(CCDEPMODE) $(depcomp) \
